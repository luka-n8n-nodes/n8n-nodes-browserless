{
	"name": "@luka-cat-mimi/n8n-nodes-browserless",
	"version": "1.2.0",
	"description": "n8n 社区节点：集成 Browserless 平台，支持网页抓取、截图、PDF生成、自动化浏览器操作",
	"keywords": [
		"n8n",
		"n8n-node",
		"n8n-community-node-package",
		"browserless",
		"scrape",
		"screenshot",
		"pdf",
		"automation",
		"headless-browser",
		"web-scraping"
	],
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"homepage": "https://github.com/luka-n8n-nodes/n8n-nodes-browserless#readme",
	"author": {
		"name": "luka-cat",
		"email": "luka.cat.mimi@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/luka-n8n-nodes/n8n-nodes-browserless.git"
	},
	"main": "index.js",
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"format": "prettier nodes credentials --write",
		"lint": "n8n-node lint",
		"lintfix": "n8n-node lint --fix",
		"test": "jest"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/BrowserlessApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Browserless/Browserless.node.js"
		]
	},
	"devDependencies": {
		"@jest/globals": "^29.7.0",
		"@n8n/node-cli": "*",
		"@types/jest": "^29.5.13",
		"@types/node": "^20.19.37",
		"eslint": "9.39.4",
		"jest": "^29.7.0",
		"prettier": "3.8.1",
		"ts-jest": "^29.2.5",
		"ts-node": "^10.9.2",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"joi": "^17.13.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
